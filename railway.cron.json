{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'cd /app/src && python fetch_firms.py && python train.py'",
    "cronSchedule": "0 6 * * *",
    "restartPolicyType": "NEVER"
  }
}
