# =====================================
# Build context exclusions
# =====================================
# Goal: keep the build context small (faster uploads to the daemon /
# Railway builders) and keep host artifacts out of the image. Anything
# the build genuinely needs (web/, src/, requirements.txt) is implicitly
# included by NOT being listed here.

.git
.gitignore
.github
.idea
.vscode
.venv
__pycache__
*.pyc
.DS_Store
*.log

# Node
web/node_modules
web/dist

# data/ + outputs/ ARE included — the entrypoint script (start.sh) seeds
# the Railway volume from these on first boot, otherwise the web service
# can't start before the daily cron has had a chance to run. Once the
# volume has fresh contents, the in-image copies are ignored.
# Exclude the training-history dir to keep image weight down.
outputs/models/history
src.zip

# Local-only / secrets
.env
.env.local
.env.*.local

# Misc
*.md
!README.md
notebooks
