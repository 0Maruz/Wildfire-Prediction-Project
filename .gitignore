# Secrets / local env
.env
.env.local

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Editor / OS
.vscode/
.claude/
.DS_Store
*.swp

# Data — fetched at runtime via fetch_firms.py / fetch_weather.py
# (keep directory scaffolding so layout is obvious, ignore contents)
data/**
!data/
!data/raw/
!data/firms/
!data/weather/
!data/**/.gitkeep
# Thailand boundary GeoJSON — checked in because risk_map.py's country
# filter needs it; small (~1 MB) and stable.
!data/boundaries/
!data/boundaries/thailand.geojson
# Hansen tree cover aggregates — small (~180 KB), regenerable via
# fetch_treecover.py but committing avoids a 7-min download on first clone.
!data/static/
!data/static/tree_cover_per_cell.parquet

# Build artifacts — regenerated by train.py / risk_map.py
outputs/**
!outputs/
!outputs/models/
!outputs/features/
!outputs/metadata/
!outputs/riskmap/
!outputs/**/.gitkeep
# Frontend pulls these two artifacts directly via relative paths, so we
# check them in to make GitHub Pages a no-op deploy. dataset_info.json is
# tiny; the GeoJSON grows over time but stays under a few MB after the
# 7-day-window pruning risk_map.append_geojson does on each run.
!outputs/riskmap/fire_dates_all.geojson
!outputs/metadata/dataset_info.json

# Misc
src.zip
Science-Project/
*.tar.gz
